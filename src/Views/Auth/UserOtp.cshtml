@{
    Layout = "_PublicLayout";
    var lang = (Context.Request?.Query["lang"].ToString() == "ar") ? "ar" : "en";
    ViewData["Title"] = lang == "ar" ? "تأكيد رمز التحقق" : "Confirm OTP";
    string T(string en, string ar) => lang == "ar" ? ar : en;
}
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body">
          <h3 class="text-center mb-4">@T("Enter OTP","أدخل رمز التحقق")</h3>

          @if (TempData["ok"] != null)
          {
            <div class="alert alert-success">@TempData["ok"]</div>
          }
          @if (TempData["err"] != null)
          {
            <div class="alert alert-danger">@TempData["err"]</div>
          }

          <form method="post" action="/user/otp@(lang=="ar"?"?lang=ar":"")">
            @Html.AntiForgeryToken()
            <input type="hidden" name="lang" value="@lang" />
            <div class="mb-3">
              <label class="form-label" for="code">@T("OTP Code","رمز التحقق")</label>
              <input id="code" name="code" class="form-control" maxlength="6" pattern="^\d{6}$" inputmode="numeric" required />
            </div>
            <button class="btn btn-primary w-100" type="submit">@T("Verify","تأكيد")</button>
          </form>

          <form method="post" action="/user/resend@(lang=="ar"?"?lang=ar":"")" class="mt-3 text-center">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-link">@T("Resend OTP","إعادة إرسال الرمز")</button>
          </form>

          <p class="mt-2 small text-muted text-center">@T("OTP expires in 5 minutes. In development, use 123456.","ينتهي الرمز خلال 5 دقائق. لأغراض التطوير استخدم 123456.")</p>
        </div>
      </div>
    </div>
  </div>
</div>
