@model MT.Data.VehicleRegistration
@{
    Layout = "_PublicLayout";
    var lang = (ViewBag.Lang as string) ?? "en";
    var rtl  = lang == "ar" ? "rtl" : "ltr";
    bool isTank = string.Equals(Model.VehicleType, "tank", StringComparison.OrdinalIgnoreCase);
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
  :root { --primary:#7C1D3A; --primary-800:#6D1933; --border:#E7E7EA; }
  .page-wrap{ padding:24px 16px; }
  .h-title{ font-weight:800; color:#222; margin-bottom:8px; }
  .lead-text{ color:#555; }
  .btn-primary{ background:var(--primary); border-color:var(--primary); color:#fff; }
  .btn-primary:hover{ background:var(--primary-800); border-color:var(--primary-800); }
  .btn-outline-primary{ color:var(--primary); border-color:var(--primary); }
  .btn-outline-primary:hover{ background:var(--primary); color:#fff; }
  .card-soft{ background:#fff; border:1px solid var(--border); border-radius:14px; box-shadow:0 6px 20px rgba(0,0,0,.05); }
  .kv-row{ padding:.65rem 0; border-bottom:1px dashed var(--border); display:flex; justify-content:space-between; align-items:center; gap:12px; }
  .kv-row:last-child{ border-bottom:0; }
  .kv-key{ color:#666; white-space:nowrap; }
  .kv-val{ font-weight:600; color:#222; text-align:end; }
  table.doc-table{ width:100%; border-collapse:collapse; }
  .doc-table th, .doc-table td{ padding:10px 12px; border-bottom:1px solid var(--border); }
  .doc-table th{ background:#fafafa; color:#333; font-weight:700; }
  .status-ok{ color:#1e7b34; font-weight:600; }
  .status-miss{ color:#999; font-weight:600; }
  .lang-toggle .btn{ border-radius:999px; }
</style>

<div class="page-wrap" dir="@rtl">
  <div class="container-fluid">

    <!-- Header -->
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
      <div>
        <h1 class="h-title" data-i="title">Vehicle Registration Details</h1>
        <p class="lead-text mb-0" data-i="lead">Below are all details and uploaded documents for this vehicle registration.</p>
      </div>
      <div class="lang-toggle">
        <a class="btn btn-outline-secondary me-2 @(lang=="en"?"active":"")"
           href="@Url.Action("Details","Vehicle", new { id = Model.Id, lang="en" })">English</a>
        <a class="btn btn-outline-secondary @(lang=="ar"?"active":"")"
           href="@Url.Action("Details","Vehicle", new { id = Model.Id, lang="ar" })">العربية</a>
      </div>
    </div>

    <!-- Owner & Driver Info -->
    <div class="card card-soft mb-4">
      <div class="card-header bg-white border-0">
        <h2 class="h6 mb-0 text-center" data-i="ownerDriver">Owner and Driver Information</h2>
      </div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-md-6"><div class="kv-row"><span class="kv-key">Owner's Phone</span><span class="kv-val">@Model.OwnerPhone</span></div></div>
          <div class="col-md-6"><div class="kv-row"><span class="kv-key">Owner Name</span><span class="kv-val">@Model.VehicleOwnerName</span></div></div>
          <div class="col-md-6"><div class="kv-row"><span class="kv-key">Driver's Phone</span><span class="kv-val">@Model.DriverPhone</span></div></div>
          <div class="col-md-6"><div class="kv-row"><span class="kv-key">Driver Name</span><span class="kv-val">@Model.DriverName</span></div></div>
          <div class="col-md-6"><div class="kv-row"><span class="kv-key">Vehicle Type</span><span class="kv-val">@Model.VehicleType</span></div></div>
        </div>
      </div>
    </div>

    <!-- Document List -->
    <div class="card card-soft mb-4">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
        <h2 class="h6 mb-0">Status</h2>
        <span class="badge @(Model.Status == "Approved" ? "bg-success" : Model.Status == "Rejected" ? "bg-danger" : Model.Status == "Under Review" ? "bg-warning text-dark" : "bg-secondary")">@Model.Status</span>
      </div>
      @if (Model.Status == "Rejected" && !string.IsNullOrWhiteSpace(Model.RejectReason))
      {
        <div class="card-body">
          <div class="mb-2"><strong>Rejected By:</strong> @(!string.IsNullOrWhiteSpace(Model.RejectedByName) ? Model.RejectedByName : "—") (@(!string.IsNullOrWhiteSpace(Model.RejectedByRole) ? Model.RejectedByRole : "—"))</div>
          <div class="mb-2"><strong>When:</strong> @(Model.RejectedAt.HasValue ? Model.RejectedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—")</div>
          <div class="mb-1"><strong>Reason:</strong></div>
          <div class="border rounded p-2 bg-light" style="white-space:pre-wrap">@Model.RejectReason</div>
        </div>
      }
    </div>

    <!-- Document List -->
    <div class="card card-soft mb-4">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
        <h2 class="h6 mb-0" data-i="docsTitle">
          @(isTank ? "Documents required for tanks" : "Documents required for trucks")
        </h2>
        <div class="d-flex gap-2">
          <a href="@Url.Action("DownloadAll","Vehicle", new { id = Model.Id })" class="btn btn-outline-primary btn-sm">
            <i class="fa-solid fa-download me-1"></i> Download All
          </a>
          <a href="@Url.Action("ExportPdf","Vehicle", new { id = Model.Id })" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-file-pdf me-1"></i> Export as PDF
          </a>
        </div>
      </div>

      <div class="card-body p-0">
        <table class="doc-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Document Name</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
                    <tbody>
                        @{
                            // Local helper
                            void Row(int n, string docName, string fileKey, string? path)
                            {
                                bool up = !string.IsNullOrWhiteSpace(path);
                                string cls = up ? "status-ok" : "status-miss";
                                string txt = up ? "Uploaded" : "Not uploaded";
                                <text>
                                <tr>
                                    <td>@n</td>
                                    <td>@docName</td>
                                    <td><span class="@cls">@txt</span></td>
                                    <td>
                                            @if (up)
                                            {
                                            <a class="btn btn-sm btn-primary"
                                               href="@Url.Action("DownloadFile","Vehicle", new { id = Model.Id, file = fileKey })">
                                                <i class="fa-solid fa-download me-1"></i> Download
                                            </a>
                                            }
                                </td>
                            </tr>
                            </text>
;
                            }

                            if (isTank)
                            {
                                Row(1, "Double-sided ID card", "IdCardBothSides", Model.IdCardBothSidesPath);
                                Row(2, "Both sides of the tanker application form", "TankerFormBothSides", Model.TankerFormBothSidesPath);
                                Row(3, "IBAN certificate from bank", "IbanCertificate", Model.IbanCertificatePath);
                                Row(4, "Tank capacity certificate", "TankCapacityCert", Model.TankCapacityCertPath);
                                Row(5, "Dumping landfill (works)", "LandfillWorks", Model.LandfillWorksPath);
                                Row(6, "Signed registration form", "SignedRegistrationForm", Model.SignedRegistrationFormPath);
                                Row(7, "Release form", "ReleaseForm", Model.ReleaseFormPath);
                            }
                            else
                            {
                                Row(1, "Double-sided ID card", "Truck_IdCard", Model.Truck_IdCardPath);
                                Row(2, "Trailer registration form", "Truck_TrailerRegistration", Model.Truck_TrailerRegistrationPath);
                                Row(3, "Traffic department certificate", "Truck_TrafficCertificate", Model.Truck_TrafficCertificatePath);
                                Row(4, "IBAN certificate", "Truck_IbanCertificate", Model.Truck_IbanCertificatePath);
                                Row(5, "Signed registration form", "Truck_VehicleRegForm", Model.Truck_VehicleRegFormPath);
                                Row(6, "Release form", "Truck_ReleaseForm", Model.Truck_ReleaseFormPath);
                            }
                        }
                    </tbody>

        </table>
      </div>
    </div>

  </div>
</div>
