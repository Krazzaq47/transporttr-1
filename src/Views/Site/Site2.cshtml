@{
    Layout = null;
    var lang = (ViewBag.Lang as string)?.ToLower() == "ar" ? "ar" : "en";
}
<!DOCTYPE html>
<html lang="@(lang == "ar" ? "ar" : "en")" dir="@(lang == "ar" ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Golden Falcon Office – Bilingual</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        :root {
            --brand: #c89a4b;
            --ink: #2a2a2a;
            --bg: #f9f6f1;
        }

        body {
            color: var(--ink);
        }

        .btn-brand {
            background: var(--brand);
            color: #fff;
            border: none;
        }

            .btn-brand:hover {
                filter: brightness(0.95);
            }

        .soft-card {
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(0,0,0,.06);
            padding: 1.5rem;
        }

        .hero {
            background: var(--bg);
            border-radius: 24px;
        }

        .muted {
            color: #6c757d;
        }

        .check-list li {
            margin-bottom: .4rem;
        }

        .section-title {
            color: var(--brand);
            font-weight: 700;
        }

        footer {
            border-top: 1px solid #eee;
        }

        .kpi {
            font-size: 3rem;
            font-weight: 800;
            color: var(--brand);
            line-height: 1;
        }
        /* Bilingual helpers */
        .lang-en, .lang-ar {
            display: none;
        }

        .show-en .lang-en, .show-ar .lang-ar {
            display: inline;
        }

            .show-en .lang-en.block, .show-ar .lang-ar.block {
                display: block;
            }
        /* RTL helpers */
        html[dir="rtl"] .text-start {
            text-align: right !important;
        }

        html[dir="rtl"] .text-end {
            text-align: left !important;
        }

        html[dir="rtl"] .ms-auto {
            margin-left: 0 !important;
            margin-right: auto !important;
        }

        html[dir="rtl"] .me-2 {
            margin-right: 0 !important;
            margin-left: .5rem !important;
        }

        html[dir="rtl"] .ps-3 {
            padding-left: 0 !important;
            padding-right: 1rem !important;
        }

        html[dir="rtl"] .form-control {
            text-align: right;
        }
    </style>

    <style>
        .check-list li {
            margin-bottom: 0.4rem;
            font-size: 0.95rem;
        }

            .check-list li::before {
                content: '✔';
                color: #c89a4b;
                margin-right: 0.5rem;
                font-weight: bold;
            }

    </style>

</head>
<body class="bg-light @(lang == "ar" ? "show-ar" : "show-en")">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">🦅 Golden Falcon</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">☰</button>
            <div id="nav" class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto gap-2">
                    <li class="nav-item"><a class="nav-link" href="#home"><span class="lang-en">Home</span><span class="lang-ar">الصفحة الرئيسية</span></a></li>
                    <li class="nav-item"><a class="nav-link" href="#about"><span class="lang-en">About</span><span class="lang-ar">من نحن</span></a></li>
                    <li class="nav-item"><a class="nav-link" href="#services"><span class="lang-en">Office</span><span class="lang-ar">مكتب الصقر الذهبي</span></a></li>
                    <li class="nav-item"><a class="nav-link" href="#requirements"><span class="lang-en">Documents</span><span class="lang-ar">المستندات</span></a></li>
                    <li class="nav-item"><a class="nav-link" href="#steps"><span class="lang-en">Steps</span><span class="lang-ar">خطوات التقديم</span></a></li>
                    <li class="nav-item"><a class="nav-link" href="#faq"><span class="lang-en">FAQ</span><span class="lang-ar">الأسئلة</span></a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact"><span class="lang-en">Contact</span><span class="lang-ar">اتصل</span></a></li>
                </ul>
                <div class="d-flex ms-3">
                    <a href="@Url.Action("site2", new { lang = "en" })" class="btn btn-sm @(lang=="en"?"btn-brand":"btn-outline-secondary") me-2">EN</a>
                    <a href="@Url.Action("Index", new { lang = "ar" })" class="btn btn-sm @(lang=="ar"?"btn-brand":"btn-outline-secondary")">العربية</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="container my-4" id="home">
        <!-- HERO -->
        <section class="hero p-4 p-lg-5 mb-4 soft-card">
            <div class="row align-items-center g-4">
                <div class="col-lg-6 order-lg-2">
                    <img src="~/img/truck_1.png" class="img-fluid rounded-4" alt="Trucks" />
                </div>
                <div class="col-lg-6">
                    <h1 class="display-6 fw-bold lang-en block">Register your request with the e‑service of Golden Falcon Office</h1>
                    <h1 class="display-6 fw-bold lang-ar block">سجّل طلبك مع الخدمة الإلكترونية لمكتب الصقر الذهبي</h1>
                    <p class="lead muted lang-en block">Submit your crusher or truck registration online. We guide you step‑by‑step and simplify paperwork so you can complete your request wherever you are.</p>
                    <p class="lead muted lang-ar block">يمكنك تسجيل كسارتك أو مركبتك من خلال منصتنا الإلكترونية التي تُرشدك خطوة بخطوة، وتُسهِّل عليك جمع المستندات وإنهاء الطلب بسهولة وأنت في مكانك.</p>
                    <a href="#contact" class="btn btn-brand btn-lg lang-en">Register Now</a>
                    <a href="#contact" class="btn btn-brand btn-lg lang-ar">سجّل الآن</a>
                </div>
            </div>
        </section>

        <!-- WHO WE ARE / KPI CARD -->
        <section id="services" class="mb-4">
            <div class="soft-card">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-8">
                        <h2 class="section-title lang-en">Golden Falcon Office for Crushers & Shipments</h2>
                        <h2 class="section-title lang-ar">مكتب الصقر الذهبي للنقليات للصهاريج والشاحنات </h2>
                        <p class="lang-en block">We coordinate between crushers/quarries and authorities to complete registrations, permits and document submissions smoothly. Our team follows up on your request to ensure fast completion and clear communication.</p>
                        <p class="lang-ar block">نحن في مكتب الصقر الذهبي نعمل كحلقة وصل بين البلديات والاعتدة الميكانيكة  والجهات المختصة لإتمام إجراءات التسجيل وتصاريح النقل وتقديم المستندات بسهولة ووضوح. ونتابع معك طلبك حتى اكتمال المعاملة بأسرع وقت.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="p-4 text-center border rounded-4 bg-white h-100">
                            <div class="kpi">150</div>
                            <div class="lang-en">More than 150 providers served</div>
                            <div class="lang-ar">خدم أكثر من 150 مقدم</div>
                        </div>
                    </div>
                </div>
            </div>
           
        </section>

